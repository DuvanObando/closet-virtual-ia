# === Sistema Experto Closet Virtual ===
# Copia este archivo a .env y rellena con tus claves reales
# NUNCA subas el archivo .env al repositorio

# Proveedor principal (multimodal - obligatorio para análisis de imágenes)
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# Proveedores de respaldo (opcionales - solo texto)
GROQ_API_KEY=tu_clave_de_groq_aqui
HF_TOKEN=tu_token_de_huggingface_aqui

# Ollama no requiere variable de entorno (corre local en localhost:11434)
